{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Which States Are Happiest?",
        "subtitle": "Overall Malaysia Happiness Index score by state, 2024",
        "fontSize": 16,
        "subtitleFontSize": 12,
        "subtitleFontStyle": "italic",
        "anchor": "start",
        "color": "#1A1209",
        "subtitleColor": "#5A4A2E"
    },
    "width": 800, 
    "height": 400,
    "projection": {
        "type": "mercator",
        "center": [112,4],
        "scale": 1800
    },
    "layer": [
        {
            "data": {
                "sphere": true
            },
            "mark": {
                "type": "geoshape",
                "fill": "#C9E8F5",
                "stroke": "none"
            }
        },
        {
            "data": {
                "graticule": {
                    "step": [5, 5]
                }
            },
            "mark": {
                "type": "geoshape",
                "filled": false,
                "stroke": "#A8D8EA",
                "strokeWidth": 0.4
            }
        },
        {
            "data": {
                "url": "data/world-110m.json",
                "format": {
                    "type": "topojson",
                    "feature": "countries"
                }
            },
            "transform": [
                {
                    "filter": "toString(datum.id) == '764' || toString(datum.id) == '360' ||  toString(datum.id) == '96' || toString(datum.id) == '608' || toString(datum.id) == '704'"
                }
            ],
            "mark": {
                "type": "geoshape",
                "fill": "#E8E0D4",
                "stroke": "#BBB0A0",
                "strokeWidth": 0.8
            }
        },
        {
            "data": {
                "url": "data/states.geojson",
                "format": {
                    "type": "json",
                    "property": "features"
                }
            },
            "transform": [
                {
                    "lookup": "properties.Name",
                    "from": {
                        "data": {
                            "url": "data/happiness_state.csv",
                            "format": {"type": "csv"}
                        },
                        "key": "state",
                        "fields": [
                            "happiness"
                        ]
                    }
                }
            ],
            "params": [
                {
                    "name": "state_hover",
                    "select": {
                        "type": "point",
                        "on": "pointerover",
                        "clear": "pointerout"
                    }
                }
            ],
            "mark": {
                "type": "geoshape",
                "stroke": "#FFFFFF",
                "strokeWidth": 1.2
            },
            "encoding": {
                "color": {
                    "condition": {
                        "test": "state_hover.happiness && datum.happiness != state_hover.happiness",
                        "value": "#CCCCCC"
                    },
                    "field": "happiness",
                    "type": "quantitative",
                    "scale": {
                        "domain": [
                            7,
                            8.7
                        ],
                        "range": [
                            "#FDE8C0",
                            "#E0A030",
                            "#8A5200"
                        ]
                    },
                    "legend": {
                        "title": "Happiness Index",
                        "orient": "bottom-right",
                        "gradientLength": 140,
                        "gradientThickness": 12,
                        "labelFontSize": 11,
                        "titleFontSize": 12, 
                        "titleColor": "#1A1209",
                        "labelColor": "#5A4A2E"
                    }
                },
                "tooltip": [
                    {
                        "field": "properties.Name",
                        "type": "nominal",
                        "title": "State"
                    },
                    {
                        "field": "happiness",
                        "type": "quantitative",
                        "title": "Happiness Index",
                        "format": ".2f"
                    }
                ]
            }
        },
        {
            "data": {
                "values": [
                    {
                        "label": "Terengganu",
                        "longitude": 103,
                        "latitude": 5.2
                    },
                    {
                        "label": "W.P. Labuan",
                        "longitude": 116.5,
                        "latitude": 5.75
                    }
                ]
            },
            "mark": {
                "type": "text",
                "fontSize": 10,
                "fontWeight": "bold",
                "color": "#1A1209", 
                "align": "center"
            },
            "encoding": {
                "longitude": {
                    "field": "longitude",
                    "type": "quantitative"
                },
                "latitude": {
                    "field": "latitude",
                    "type": "quantitative"
                },
                "text": {
                    "field": "label",
                    "type": "nominal"
                }
            }
        }
    ],
    "config": {
        "view": {
            "stroke": "transparent"
        }
    }
}