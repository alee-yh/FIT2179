{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 800,
  "height": 500,

  "background": "#d9eaf7",

  "title": {
    "text": "Malaysian Happiness Index (MHI) by state",
    "anchor": "start",
    "fontSize": 16,
    "color": "#5a4a2e"
  },

  "projection": {
    "type": "mercator",
    "center": [109.5, 4.2],
    "scale": 1850
  },

  "layer": [

    {
      "data": {
        "sphere": true
      },

      "mark": {
        "type": "geoshape",
        "fill": "#d9eaf7"
      }
    },
    {
        "data": {
            "graticule": {
                "step": [3,3]
            }
        },
        "mark": {
            "type": "geoshape",
            "stroke": "#b8c6d1",
            "strokeWidth": 0.6
        }
    },
    {
      "data": {
        "url": "data/states_provinces.json",

        "format": {
          "type": "topojson",
          "feature": "ne_10m_admin_1_states_provinces"
        }
      },

      "mark": {
        "type": "geoshape",
        "fill": "#aeaeae",
        "stroke": "#656464",
        "strokeWidth": 0.5
      }
    },

    {
      "data": {
        "url": "data/states_provinces.json",

        "format": {
          "type": "topojson",
          "feature": "ne_10m_admin_1_states_provinces"
        }
      },

      "transform": [

        {
          "filter": "datum.properties.admin == 'Malaysia'"
        },

        {
          "lookup": "properties.name",

          "from": {
            "data": {
              "url": "data/happiness_state.csv"
            },

            "key": "state",

            "fields": ["happiness"]
          }
        }
      ],

      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 0.8
      },

      "encoding": {

        "color": {
          "field": "happiness",
          "type": "quantitative",

          "scale": {
            "scheme": "tealblues"
          },

          "title": "Happiness Index"
        },

        "tooltip": [

          {
            "field": "properties.name",
            "type": "nominal",
            "title": "State"
          },

          {
            "field": "happiness",
            "type": "quantitative",
            "title": "Happiness",
            "format": ".2f"
          }
        ]
      }
    }

  ],

  "config": {
    "view": {
      "stroke": null
    }
  }
}