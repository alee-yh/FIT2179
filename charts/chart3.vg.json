{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "How Happy are Malaysians, State by State?",
        "subtitle": "Happiness index by state. Scale: 0 (least happy) to 10 (most happy)",
        "subtitleFontStyle": "italic",
        "subtitleFontSize": 12,
        "fontSize": 16,
        "anchor": "start",
        "color": "#1a1209",
        "subtitleColor": "#5a4a2e"
    },
     "width": 700,
     "height": 500,
     "data": {
        "url": "data/states.geojson",
        "format": {"type": "json", "property": "features"}
     },
     "transform": [
        {
            "lookup": "properties.Name",
            "from": {
                "data": {
                    "url": "data/happiness_state.csv",
                    "format": {"type": "csv"}
            },
            "key": "state",
            "fields": ["happiness"]
            }
        }
     ],
     "projection": {"type": "mercator", "scale": 1800, "center": [109.65, 4]},
     "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 1
     },
     "encoding": {
        "color": {
            "field": "happiness",
            "type": "quantitative",
            "scale": {
                "domain": [7, 8.7],
                "range": [
                    "#fde8c0", "#e0a030", "#7a4e06"
                ]
            },
            "legend": {
                "title": "Happiness Index",
                "orient": "bottom-right",
                "gradientLength": 140,
                "gradientThickness": 12,
                "labelFontSize": 11,
                "titleFontSize": 12,
                "titleColor": "#1a1209",
                "labelColor": "#5a4a2e"
            }
        },
        "tooltip": [
            {
                "field": "properties.Name",
                "type": "nominal",
                "title": "State"
            },
            {
                "field": "happiness",
                "type": "quantitative",
                "title": "Happiness Index",
                "format": ".2f"
            }
        ]
     },
     "config": {
        "view": {
            "stroke": "transparent"
        }
     }
}