{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Which States Are Happiest?",
        "subtitle": "Overall Malaysia Happiness Index score by state, 2024",
        "fontSize": 16,
        "subtitleFontSize": 12,
        "anchor": "start"
    },
    "width": 700,
    "height": 300,
    "data": {
        "url": "data/states.geojson",
        "format": {"type": "json", "property": "features"}
    },
    "transform": [
        {
            "lookup": "properties.Name",
            "from": {
                "data": {
                    "url": "data/happiness_state.csv",
                    "format": {"type": "csv"}
                },
                "key": "state",
                "fields": ["happiness"]
            }
        }
    ],
    "projection": {"type": "mercator", "scale": 1800, "center": [109.65, 4]},
    "mark": {"type": "geoshape", "stroke": "white", "strokeWidth": 0.5},
    "encoding": {
        "color": {
            "field": "happiness",
            "type": "quantitative",
            "scale": {"scheme": "yelloworangered"},
            "title": "Happiness Score"
        },
        "tooltip": [
            {"field": "properties.Name", "title": "State"},
            {"field": "happiness", "title": "Happiness Score", "format": ".2f"}
        ]
    }
}