{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Malaysia Happiness Index (MHI) scores across 13 life domains",
    "fontSize": 16,
    "anchor": "start",
    "color": "#5a4a2e"
  },
  "width": 850,
  "height": 450,
  "data": {
    "url": "data/happiness_national.csv",
    "format": {"type": "csv"}
  },
  "layer": [
    {
        "mark": {"type": "rule", "strokeWidth": 1.5, "color": "#1a1209"},
        "encoding": {
            "y": {"field": "component", "type": "nominal", "sort": "x"},
            "x": {"field": "score", "type": "quantitative"},
            "x2":{"value": 0}
        }
    },
    {
        "mark": {"type": "point", "filled": true, "size": 120},
        "encoding": {
            "y":{
                "field": "component",
                "type": "nominal",
                "sort": "x",
                "title": null
            },
            "x":{
                "field": "score",
                "type": "quantitative",
                "title": "Happiness Score (scale: 0-10)",
                "scale": {"domain": [5.5, 9.5]}
            },
            "color":{
                "condition":{
                    "test": "datum.score < 7.6",
                    "value": "#4a90b8"
                },
                "value": "#c8860a"
            },
            "tooltip": [
                {"field": "component", "title": "Domain"},
                {"field": "score", "title": "Score", "format": ".2f"}
            ]
        }
    },
    {
        "mark":{
            "type": "rule",
            "strokeDash": [4, 4],
            "color": "#1a1209",
            "strokeWidth": 1.2
        },
        "encoding": {
            "x": {"datum": 7.6}
        }
    },
    {
        "mark": {
            "type": "text",
            "align":"center",
            "dx": 4,
            "dy": -179,
            "fontSize": 10,
            "color": "#1a1209",
            "text": "National Average: 7.6"
        },
        "encoding": {
            "x": {"datum": 7.6}
        }
    }
  ],
  "config": {
    "view": {
        "stroke": "transparent"
    }
  }
}