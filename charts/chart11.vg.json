{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Median household income at the 50th percentile by state",
        "fontSize": 16,
        "anchor": "start",
        "color": "#5a4a2e"
    },
    "width": 590,
    "height": 420,
    "data": {
        "url": "data/income_growth.csv"
    },
    "params": [
        {
            "name": "income_hovered_line",
            "value": "",
            "bind": {
                "input": "select",
                "options": [
                    "",
                    "Johor",
                    "Kedah",
                    "Kelantan",
                    "Melaka",
                    "Negeri Sembilan",
                    "Pahang",
                    "Perak",
                    "Perlis",
                    "Pulau Pinang",
                    "Sabah",
                    "Sarawak",
                    "Selangor",
                    "Terengganu",
                    "W.P. Kuala Lumpur",
                    "W.P. Labuan",
                    "W.P. Putrajaya"
                ],
                "labels": [
                    "All states",
                    "Johor",
                    "Kedah",
                    "Kelantan",
                    "Melaka",
                    "Negeri Sembilan",
                    "Pahang",
                    "Perak",
                    "Perlis",
                    "Pulau Pinang",
                    "Sabah",
                    "Sarawak",
                    "Selangor",
                    "Terengganu",
                    "W.P. Kuala Lumpur",
                    "W.P. Labuan",
                    "W.P. Putrajaya"
                ],
                "name": "Highlight state: "
            }
        }
    ],
    "layer": [
        {
            "mark": {
                "type": "line",
                "point": true,
                "strokeWidth": 1.8
            },
            "encoding": {
                "x": {
                    "field": "year",
                    "type": "ordinal",
                    "title": "Year",
                    "axis": {
                        "labelFontSize": 12,
                        "titleFontSize": 13,
                        "labelAngle": 0,
                        "titleColor": "#1a1209",
                        "gridColor": "#ede8df",
                        "gridOpacity": 0.8,
                        "domainColor": "#d4c5a9",
                        "tickColor": "#d4c5a9"
                    }
                },
                "y": {
                    "field": "income",
                    "type": "quantitative",
                    "title": "Median Monthly Income (RM)",
                    "scale": {
                        "domain": [3000, 12000]
                    },
                    "axis": {
                        "format": ",.0f",
                        "tickCount": 6,
                        "labelFontSize": 11,
                        "titleFontSize": 13,
                        "titleColor": "#1a1209",
                        "gridColor": "#ede8df",
                        "gridOpacity": 0.8
                    }
                },
                "detail": {
                    "field": "state",
                    "type": "nominal"
                },
                "color": {
                    "field": "state",
                    "type": "nominal",
                    "scale": {
                        "domain": [
                            "Johor",
                            "Kedah",
                            "Kelantan",
                            "Melaka",
                            "Negeri Sembilan",
                            "Pahang",
                            "Perak",
                            "Perlis",
                            "Pulau Pinang",
                            "Sabah",
                            "Sarawak",
                            "Selangor",
                            "Terengganu",
                            "W.P. Kuala Lumpur",
                            "W.P. Labuan",
                            "W.P. Putrajaya"
                        ],
                        "range": [
                            "#e69f00",
                            "#56b4e9",
                            "#009e73",
                            "#f0e442",
                            "#0072b2",
                            "#cc79a7",
                            "#332288",
                            "#882255",
                            "#aa4499",
                            "#d55e00",
                            "#cc6677",
                            "#117733",
                            "#44aa99",
                            "#648fff",
                            "#785ef0",
                            "#dc267f"
                        ]
                    },
                    "legend": {
                        "title": "State",
                        "orient": "right",
                        "labelFontSize": 10,
                        "titleFontSize": 11,
                        "titleColor": "#1a1209",
                        "labelColor": "#5a4a2e",
                        "symbolSize": 60
                    }
                },
                "strokeWidth": {
                    "condition": {
                        "test": "income_hovered_line != '' && datum.state == income_hovered_line",
                        "value": 3
                    },
                    "value": 1.4
                },
                "opacity": {
                    "condition": {
                        "test": "income_hovered_line != '' && datum.state != income_hovered_line",
                        "value": 0.08
                    },
                    "value": 0.85
                },
                "tooltip": [
                    {
                        "field": "state",
                        "type": "nominal",
                        "title": "State"
                    },
                    {
                        "field": "year",
                        "type": "ordinal",
                        "title": "Year"
                    },
                    {
                        "field": "income",
                        "type": "quantitative",
                        "title": "Median Income (RM)",
                        "format": ",.0f"
                    }
                ]
            }
        },
        {
            "transform": [
                {
                    "filter": "datum.year == 2024"
                },
                {
                    "filter": "income_hovered_line != '' && datum.state == income_hovered_line"
                }
            ],
            "mark": {
                "type": "text",
                "align": "left",
                "dx": 6,
                "fontSize": 11,
                "fontWeight": "bold",
                "color": "#1a1209"
            },
            "encoding": {
                "x": {
                    "field": "year",
                    "type": "ordinal"
                },
                "y": {
                    "field": "income",
                    "type": "quantitative"
                },
                "text": {
                    "field": "state",
                    "type": "nominal"
                }
            }
        }
    ],
    "config": {
        "view": {
            "stroke": "transparent"
        }
    }
}