{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Median household income vs. happiness index",
        "fontSize": 16,
        "anchor": "start",
        "color": "#5a4a2e"
    },
    "width": 850, 
    "height": 250,
    "data": {
        "url": "data/scatter_data.csv"
    },
    "layer": [
        {
            "transform": [
                {
                    "regression": "happiness",
                    "on": "income",
                    "extent": [3500, 11500]
                }
            ],
            "mark": {
                "type": "line",
                "color": "#c8860a",
                "strokeWidth": 2,
                "strokeDash": [6, 3],
                "opacity": 0.7
            },
            "encoding": {
                "x": {
                    "field": "income",
                    "type": "quantitative"
                },
                "y": {
                    "field": "happiness",
                    "type": "quantitative"
                }
            }
        },
        {
            "mark": {
                "type": "point",
                "filled": true,
                "color": "#c8860a",
                "size": 200,
                "opacity": 0.25,
                "stroke": "#7d7b7b",
                "strokeWidth": 1.2
            },
            "encoding": {
                "x": {
                    "field": "income",
                    "type": "quantitative",
                    "title": "Median Household Income (RM)",
                    "scale": {
                        "domain": [3500, 11500]
                    },
                    "axis": {
                        "tickCount": 6,
                        "format": ",.0f",
                        "labelFontSize": 11,
                        "titleFontSize": 13,
                        "titleColor": "#1a1209",
                        "gridColor": "#ede8df",
                        "gridOpacity": 0.8
                    }
                },
                "y": {
                    "field": "happiness",
                    "type": "quantitative",
                    "title": "Happiness Index",
                    "scale": {
                        "domain": [6.8, 8.8]
                    },
                    "axis": {
                        "tickCount": 5,
                        "labelFontSize": 11,
                        "titleFontSize": 13,
                        "titleColor": "#1a1209",
                        "gridColor": "#ede8df",
                        "gridOpacity": 0.8
                    }
                },
                "tooltip": [
                    {
                        "field": "state",
                        "type": "nominal",
                        "title": "State"
                    },
                    {
                        "field": "income",
                        "type": "quantitative",
                        "title": "Median Income (RM)",
                        "format": ",.0f"
                    },
                    {
                        "field": "happiness",
                        "type": "quantitative",
                        "title": "Happiness Index (0-10)",
                        "format": ".2f"
                    }
                ]
            }
        },
