{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Income gap between 90th and 10th percentile",
    "subtitle": "Zoom in to see gap clearly",
    "subtitleFontStyle": "italic",
    "fontSize": 16,
    "subtitleFontSize": 12,
    "anchor": "start",
    "color": "#5a4a2e",
    "subtitleColor": "#1a1209"
  },
  "width": 800,
  "height": 400,
  "params": [
    {
        "name": "zoom_scale",
        "value": 1800,
        "bind": {
            "input": "range",
            "min": 1800,
            "max": 6000,
            "step": 100,
            "name": "Zoom: "
        }
    },
    {
        "name": "center_lon",
        "value": 109.69,
        "bind": {
            "input": "range",
            "min": 99,
            "max": 120,
            "step": 0.5,
            "name": "Pan East to West: "
        }
    }
  ],
  "projection": {
    "type": "mercator",
    "center": {
        "expr": "[center_lon, 3.95]"
    },
    "scale": {
        "expr": "zoom_scale"
    }
  },
  "layer": [
    {
      "data": {
        "url": "data/oceans.json",
        "format": {
          "type": "json",
          "property": "features"
        }
      },
      "mark": {
        "type": "geoshape",
        "fill": "#c9e8f5",
        "stroke": "none"     
      }
    },
    {
      "data": {
        "url": "data/WorldMapWithGraticules.topojson",
        "format": {
          "type": "topojson",
          "feature": "ne_110m_graticules_30"
        }
      },
      "mark": {
        "type": "geoshape",
        "filled": false,
        "stroke": "#6da3b7",
        "strokeWidth": 0.7,
        "strokeOpacity": 0.8
      }
    },

    {
      "data": {
        "url": "data/states_provinces.json",
        "format": {
            "type": "topojson",
            "feature": "ne_10m_admin_1_states_provinces"
        }
      },
      "transform": [
        {
            "filter": "datum.properties.adm0_a3 == 'MYS'"
        },
        {
            "lookup": "properties.name",
            "from": {
                "data": {
                    "url": "data/inequality_map_data.csv"
                },
                "key": "topo_name",
                "fields": [
                    "state",
                    "inequality_gap",
                    "happiness",
                    "p10",
                    "p90"
                ]
            }
        }
      ],
      "mark": {
        "type": "geoshape",
        "fill": "#eadac3",
        "stroke": "#000000",
        "strokeWidth": 0.8
      }
    },
    {
        "data": {
            "url": "data/states_provinces.json",
            "format": {
                "type": "topojson",
                "feature": "ne_10m_admin_1_states_provinces"
            }
        },
        "transform": [
            {
                "filter": "datum.properties.adm0_a3 == 'MYS'"
            },
            {
                "lookup": "properties.name",
                "from": {
                    "data": {
                        "url": "data/inequality_map_data.csv"
                    },
                    "key": "topo_name",
                    "fields": [
                        "state",
                        "inequality_gap",
                        "happiness",
                        "p10",
                        "p90"
                    ]
                }
            }
        ],
        "mark": {
            "type": "circle",
            "opacity": 0.6,
            "stroke": "#ffffff",
            "strokeWidth": 1
        },
        "encoding": {
            "longitude": {
                "field": "properties.longitude",
                "type": "quantitative"
            },
            "latitude": {
                "field": "properties.latitude",
                "type": "quantitative"
            },
            "size": {
                "field": "inequality_gap",
                "type": "quantitative",
                "scale": {
                    "domain": [7000, 20000],
                    "range": [80, 2800]
                },
                "legend": {
                    "title": "Income Gap (RM)",
                    "orient": "left",
                    "symbolFillColor": "#888",
                    "labelFontSize": 10,
                    "titleFontSize": 11,
                    "titleColor": "#1a1209",
                    "labelColor": "#5a4a2e",
                    "values": [
                        8000,
                        12000,
                        16000,
                        20000
                    ]
                }
            },
            "color": {
                "field": "happiness",
                "type": "quantitative",
                "scale": {
                    "domain": [7, 8.7],
                    "range": [
                        "#fde8c0",
                        "#e0a030",
                        "#7a4e06"
                    ]
                },
                "legend": {
                    "title": "Happiness Index",
                    "orient": "top-right",
                    "gradientLength": 120,
                    "gradientThickness": 10,
                    "labelFontSize": 10,
                    "titleFontSize": 11,
                    "titleColor": "#1a1209",
                    "labelColor": "#5a4a2e"
                }
            },
            "tooltip": [
                {
                    "field": "state",
                    "type": "nominal",
                    "title": "State"
                },
                {
                    "field": "happiness",
                    "type": "quantitative",
                    "title": "Happiness Index",
                    "format": ".2f"
                },
                {
                    "field": "inequality_gap",
                    "type": "quantitative",
                    "title": "Income Gap P90-P10 (RM)",
                    "format": ",.0f"
                },
                {
                    "field": "p10",
                    "type": "quantitative",
                    "title": "P10 Income (RM)",
                    "format": ",.0f"
                },
                {
                    "field": "p90",
                    "type": "quantitative",
                    "title": "P90 Income (RM)",
                    "format": ",.0f"
                }
            ]
        }
    }
  ],
  "config": {
    "view": {
        "stroke": "transparent"
    }
  }
}