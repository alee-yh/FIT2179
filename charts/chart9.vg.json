{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "What Makes Each Ethnic Group in Malaysia Happy?",
        "subtitle": "Happiness index scores across key life domains by ethnic group, 2024.",
        "subtitleFontStyle": "italic",
        "fontSize": 16,
        "subtitleFontSize": 12,
        "anchor": "start",
        "color": "#1a1209",
        "subtitleColor": "#5a4a2e"
    },
    "width": 350,
    "height": 509,
    "data": {
        "url": "data/happiness_by_ethnicity.csv"
    },
    "mark": {
        "type": "bar"
    },
    "encoding": {
        "x": {
            "field": "ethnicity",
            "type": "nominal",
            "sort": [
                "Bumiputera",
                "Chinese",
                "Indians",
                "Others"
            ],
            "title": "Ethnic Group",
            "axis": {
                "labelFontSize": 12,
                "labelColor": "#1a1209",
                "labelAngle": 0,
                "titleFontSize": 13,
                "titleColor": "#1a1209",
                "domainColor": "#d4c5a9",
                "tickColor": "#d4c5a9"
            }
        },
        "y": {
            "field": "score",
            "type": "quantitative",
            "title": "Happiness Score (Stacked)",
            "stack": "zero",
            "axis": {
                "labelFontSize": 11,
                "titleFontSize": 13,
                "titleColor": "#1a1209",
                "gridColor": "#ede8df",
                "gridOpacity": 0.8
            }
        },
        "color": {
            "field": "component",
            "type": "nominal",
            "sort": [
                "Family",
                "Income",
                "Working Life",
                "Emotional",
                "Housing",
                "Education"
            ],
            "scale": {
                "domain": [
                    "Family",
                    "Income",
                    "Working Life",
                    "Emotional",
                    "Housing",
                    "Education"
                ],
                "range": [
                    "#7a4e06",
                    "#c8860a",
                    "#e8b84b",
                    "#f5d48a",
                    "#a8c97a",
                    "#5fa65f"
                ]
            },
            "legend": {
                "title": "Life Domain",
                "orient": "right",
                "titleFontSize": 12,
                "labelFontSize": 11,
                "titleColor": "#1a1209",
                "labelColor": "#1a1209"
            }
        },
        "tooltip": [
            {
                "field": "ethnicity",
                "type": "nominal",
                "title": "Ethnic Group"
            },
            {
                "field": "component",
                "type": "nominal",
                "title": "Domain"
            },
            {
                "field": "score",
                "type": "quantitative",
                "title": "Happiness Score",
                "format": ".2f"
            }
        ]
    },
    "config": {
        "view": {
            "stroke": "transparent"
        }
    }
}