{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Male vs. female happiness index by state",
        "fontSize": 16,
        "subtitleFontSize": 12,
        "anchor": "start",
        "color": "#1a1209",
        "subtitleColor": "#5a4a2e"
    },
    "width": 350,
    "height": 460,
    "data": {
        "url": "data/happiness_by_gender.csv"
    },
    "params": [
        {
            "name": "highlighted_state",
            "value": "",
            "bind": {
                "input": "select",
                "options": [
                    "",
                    "Johor",
                    "Kedah",
                    "Kelantan",
                    "Melaka",
                    "Negeri Sembilan",
                    "Pahang",
                    "Perak",
                    "Perlis",
                    "Pulau Pinang",
                    "Sabah",
                    "Sarawak",
                    "Selangor",
                    "Terengganu",
                    "W.P. Kuala Lumpur",
                    "W.P. Labuan",
                    "W.P. Putrajaya"
                ],
                "labels": [
                    "None",
                    "Johor",
                    "Kedah",
                    "Kelantan",
                    "Melaka",
                    "Negeri Sembilan",
                    "Pahang",
                    "Perak",
                    "Perlis",
                    "Pulau Pinang",
                    "Sabah",
                    "Sarawak",
                    "Selangor",
                    "Terengganu",
                    "W.P. Kuala Lumpur",
                    "W.P. Labuan",
                    "W.P. Putrajaya"
                ],
                "name": "Highlight state: "
            }
        }
    ],
    "transform": [
        {
            "fold": [
                "male_happiness",
                "female_happiness"
            ],
            "as": [
                "gender",
                "happiness"
            ]
        },
        {
            "calculate": "datum.gender == 'male_happiness' ? 'Male' : 'Female'",
            "as": "gender_label"
        }
    ],
    "layer": [
        {
            "mark": {
                "type": "line"
            },
            "encoding": {
                "x": {
                    "field": "gender_label",
                    "type": "nominal",
                    "sort": ["Male", "Female"],
                    "title": null,
                    "axis": {
                        "labelFontSize": 13,
                        "labelFontWeight": "bold",
                        "labelColor": "#1a1209",
                        "domainColor": "#d4c5a9",
                        "tickColor": "#d4c5a9",
                        "labelAngle": 0
                    }
                },
                "y": {
                    "field": "happiness",
                    "type": "quantitative",
                    "title": "Happiness Index",
                    "scale": {
                        "domain": [6.8, 8.8]
                    },
                    "axis": {
                        "tickCount": 5,
                        "labelFontSize": 11,
                        "titleFontSize": 13,
                        "titleColor": "#1a1209",
                        "gridColor": "#ede8df",
                        "gridOpacity": 0.8
                    }
                },
                "detail": {
                    "field": "state",
                    "type": "nominal"
                },
                "color": {
                    "condition": [
                        {
                            "test": "highlighted_state != '' && datum.state == highlighted_state",
                            "value": "#2d2d2d"
                        },
                        {
                            "test": "highlighted_state != '' && datum.state != highlighted_state",
                            "value": "#e0d9d0"
                        },
                        {
                            "test": "highlighted_state == '' && datum.female_happiness > datum.male_happiness",
                            "value": "#d5a6bd"
                        }
                    ],
                    "value": "#4a90b8"
                },
                "opacity": {
                    "condition": {
                        "test": "highlighted_state != '' && datum.state != highlighted_state",
                        "value": 0.25
                    },
                    "value": 0.75
                },
                "strokeWidth": {
                    "condition": {
                        "test": "highlighted_state != '' && datum.state == highlighted_state",
                        "value": 3
                    },
                    "value": 1.5
                }
            }
        },
        {
            "mark": {
                "type": "point",
                "filled": true,
                "size": 45
            },
            "encoding": {
                "x": {
                    "field": "gender_label",
                    "type": "nominal",
                    "sort": ["Male", "Female"]
                },
                "y": {
                    "field": "happiness",
                    "type": "quantitative"
                },
                "color": {
                    "condition": [
                        {
                            "test": "highlighted_state != '' && datum.state == highlighted_state",
                            "value": "#2d2d2d"
                        },
                        {
                            "test": "highlighted_state != '' && datum.state != highlighted_state",
                            "value": "#e0d9d0"
                        },
                        {
                            "test": "highlighted_state == '' && datum.female_happiness > datum.male_happiness",
                            "value": "#d5a6bd"
                        }
                    ],
                    "value": "#4a90b8"
                },
                "opacity": {
                    "condition": {
                        "test": "highlighted_state != '' && datum.state != highlighted_state",
                        "value": 0.25
                    },
                    "value": 1
                },
                "tooltip": [
                    {
                        "field": "state",
                        "type": "nominal",
                        "title": "State"
                    },
                    {
                        "field": "gender_label",
                        "type": "nominal",
                        "title": "Gender"
                    },
                    {
                        "field": "happiness",
                        "type": "quantitative",
                        "title": "Happiness Index",
                        "format": ".2f"
                    }
                ]
            }
        },
        {
            "transform": [
                {
                    "filter": "datum.gender_label == 'Female'"
                },
                {
                    "filter": "datum.state == 'Terengganu' || datum.state == 'W.P. Labuan' || datum.state == 'Perak' || datum.state == 'Sabah'"
                },
                {
                    "filter": "highlighted_state == ''"
                }
            ],
            "mark": {
                "type": "text",
                "align": "left",
                "fontSize": 10,
                "fontWeight": "bold",
                "color": "#1a1209",
                "dx": 10
            },
            "encoding": {
                "x": {
                    "field": "gender_label",
                    "type": "nominal",
                    "sort": ["Male", "Female"]
                },
                "y": {
                    "field": "happiness",
                    "type": "quantitative"
                },
                "text": {
                    "field": "state",
                    "type": "nominal"
                }
            }
        },
        {
            "transform": [
                {
                    "filter": "datum.gender_label == 'Female'"
                },
                {
                    "filter": "highlighted_state != '' && datum.state == highlighted_state"
                }
            ],
            "mark": {
                "type": "text",
                "align": "left",
                "fontSize": 11,
                "fontWeight": "bold",
                "color": "#2d2d2d",
                "dx": 8
            },
            "encoding": {
                "x": {
                    "field": "gender_label",
                    "type": "nominal",
                    "sort": ["Male", "Female"]
                },
                "y": {
                    "field": "happiness",
                    "type": "quantitative"
                },
                "text": {
                    "field": "state",
                    "type": "nominal"
                }
            }
        }       
    ],
    "config": {
        "view": {
            "stroke": "transparent"
        }
    }
}