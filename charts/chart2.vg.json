{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Happiness Across Every Life Domain by State",
        "subtitle": "Each cell shows a state's happiness score for that domain. Darker = higher score.",
        "fontSize": 16,
        "subtitleFontSize": 12,
        "anchor": "start"
    },
    "width": 500,
    "height": 350,
    "data": {
        "url": "data/happiness_components.csv",
        "format": {"type": "csv"}
    },
    "transform": [
        {
            "fold": ["family", "housing", "social", "health", "communication", "education", "work", "income_happiness", "safety", "time_use", "culture", "religion", "emotional"],
            "as": ["domain", "score"]
        }
    ],
    "mark": "rect",
    "encoding": {
        "y":{
            "field":"state",
            "type": "nominal",
            "title": null,
            "sort": "-x"
        },
        "x":{
            "field":"domain",
            "type": "nominal",
            "title": null,
            "sort": "-x"
        },
        "color":{
            "field":"score",
            "type": "quantitative",
            "scale":{"scheme": "blues"},
            "title": "Score"
        },
        "tooltip": [
            {"field": "state", "title": "State"},
            {"field": "domain", "title": "Domain"},
            {"field": "score", "title": "Score", "format": ".2f"}
        ]
    }
}