{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Happiness index scores by age groups and life domain",
        "fontSize": 16,
        "anchor": "start",
        "color": "#5a4a2e"
    },
    "width": 560,
    "height": 260,
    "data": {
        "url": "data/happiness_by_age.csv"
    },
    "mark": {
        "type": "rect"
    },
    "encoding": {
        "x": {
            "field": "age_group",
            "type": "ordinal",
            "sort": {
                "field": "age_group",
                "order": "ascending"
            },
            "title": "Age Group",
            "axis": {
                "labelAngle": 0,
                "labelFontSize": 11,
                "titleFontSize": 12,
                "titleColor": "#1a1209",
                "domainColor": "#d4c5a9",
                "tickColor": "#d4c5a9"
            }
        },
        "y": {
            "field": "component",
            "type": "nominal",
            "sort": [
                "Family",
                "Religion",
                "Time Use",
                "Health",
                "Working Life",
                "Total",
                "Emotional",
                "Income"
            ],
            "title": null,
            "axis": {
                "labelFontSize": 11,
                "labelColor": "#1a1209",
                "domainColor": "#d4c5a9",
                "tickColor": "#d4c5a9"
            }
        },
        "color": {
            "field": "score",
            "type": "quantitative",
            "scale": {
                "domain": [
                    5.8,
                    8.9
                ],
                "range": [
                    "#d2d2e7",
                    "#9b98c8",
                    "#5d3997"
                ]
            },
            "legend": {
                "title": "Happiness Score",
                "orient": "right",
                "gradientLength": 140,
                "gradientThickness": 12,
                "labelFontSize": 10,
                "titleFontSize": 11,
                "titleColor": "#1a1209",
                "labelColor": "#5a4a2e"
            }
        },
        "tooltip": [
            {
                "field": "age_group",
                "type": "ordinal",
                "title": "Age Group"
            },
            {
                "field": "component",
                "type": "nominal",
                "title": "Domain"
            },
            {
                "field": "score",
                "type": "quantitative",
                "title": "Happiness Score",
                "format": ".2f"
            }
        ]
    },
    "config": {
        "view": {
            "stroke": "transparent"
        }
    }
}